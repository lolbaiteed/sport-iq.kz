---
import { getGlobal } from "../lib/strapi";
import LangSwitcher from "../components/LangSwitcher.astro";
const { description = "Powered by Astro + Strapi" } = Astro.props;
const logoUrl = `${import.meta.env.STRAPI_URL}/uploads/OJSWM_055467dec8.png`;
const logosFooter = [ `${import.meta.env.STRAPI_URL}/uploads/obl_e53d7a03ac.png`,
`${import.meta.env.STRAPI_URL}/uploads/oblsport_63bf1ff9c0.png`,
`${import.meta.env.STRAPI_URL}/uploads/OJSWM_055467dec8.png`];
const global = await getGlobal();
const { Title, loginBtn, PhoneNumber, LangSwitch, FooterTitle, FooterAddr } = global ?? {};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{Title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

  </head>

  <body class="bg-background-primary text-brand-primary font-montserrat antialiased">
    <!-- Navbar -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur border-b border-slate-200">
      <div class="max-w-[1600px] mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex flex-row justify-center">
          <img src={logoUrl} class="w-28 mr-4" />
          <a href="/" class="font-montserrat text-2xl not-italic font-bold text-brand-primary tracking-tight self-center">{Title}</a>
        </div>
        <nav class="flex gap-6 text-xl font-medium text-slate-50">
          <p class="text-brand-primary self-center"><i class="fa-solid fa-phone"></i> {PhoneNumber}</p>
          <LangSwitcher langSwitch={LangSwitch} />
          <button class="bg-brand-primary px-6 py-1 rounded-xl">{loginBtn}</button>
        </nav>
      </div>
    </header>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-24 border-t border-slate-200 bg-white">
      <div class="flex flex-row bg-brand-primary w-full h-96 gap-20">
        <div class="flex flex-col w-68 text-start mt-12 ml-20 font-montserrat gap-6">
          <h1 class="text-yellow-500 font-bold text-xl">{FooterTitle}</h1>
          <p class="text-white"><i class="fa-solid fa-location-dot mr-4"></i>{FooterAddr}</p>
          <p class="text-white"><i class="fa-solid fa-phone mr-4"></i>{PhoneNumber}</p>
          <div class="flex flex-row gap-6">
            <a href="https://www.instagram.com/shvsm_olympic_zhetisu" class="text-white text-2xl self-start no-underline"><i class="fa-brands fa-instagram"></i></a>
            <a href="https://www.instagram.com/jetisu_obl.sport?igsh=ZDI5M3c0Z2VkYXll" class="text-white text-2xl self-start no-underline"><i class="fa-brands fa-instagram"></i></a>
          </div>
        </div>
        <div class="flex flex-row mt-12 gap-12">
          {logosFooter.map(logo => (
            <img src={logo} alt="" class="w-[220px] h-[220px]"></img>
          ))}
        </div>
        <div class="flex flex-row mt-12 border-yellow-500 border rounded-xl h-[300px]">
        </div<div style="position:relative;overflow:hidden;">
          <a href="https://yandex.kz/maps/ru/10303/taldikorgan/?utm_medium=mapframe&utm_source=maps" style="color:#eee;font-size:12px;position:absolute;top:0px;">Талдыкорган</a>
          <a href="https://yandex.kz/maps/ru/10303/taldikorgan/house/bolashaq_yqsham_audany_4/Y0EYdQNmTUIPQFpufXV4dnlkbQ==/?ll=78.348039%2C44.997493&utm_medium=mapframe&utm_source=maps&z=18.2" style="color:#eee;font-size:12px;position:absolute;top:14px;">Микрорайон Болашак, 4 — Яндекс Карты</a>
          <iframe src="https://yandex.kz/map-widget/v1/?ll=78.348039%2C44.997493&mode=whatshere&whatshere%5Bpoint%5D=78.346418%2C44.997561&whatshere%5Bzoom%5D=17&z=18.2" width="500" height="300" frameborder="1" allowfullscreen="true" style="position:relative;"></iframe>
        </div>
      </div>
    </footer>
  </body>
</html>
