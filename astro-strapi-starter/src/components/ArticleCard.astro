---
const { article } = Astro.props;
const { title, description, slug, publishedAt, cover } = article.attributes;

const imageUrl = cover?.data?.attributes?.url
  ? (cover.data.attributes.url.startsWith('http')
      ? cover.data.attributes.url
      : `${import.meta.env.STRAPI_URL || 'http://localhost:1337'}${cover.data.attributes.url}`)
  : null;

const date = publishedAt
  ? new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-slate-100">
  {imageUrl && (
    <a href={`/blog/${slug}`}>
      <img
        src={imageUrl}
        alt={title}
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </a>
  )}
  <div class="p-6">
    {date && <p class="text-xs text-slate-400 mb-2">{date}</p>}
    <h2 class="font-display text-xl font-bold text-slate-900 mb-2 leading-snug">
      <a href={`/blog/${slug}`} class="hover:text-brand-600 transition-colors">{title}</a>
    </h2>
    {description && <p class="text-slate-500 text-sm leading-relaxed line-clamp-3">{description}</p>}
    <a
      href={`/blog/${slug}`}
      class="inline-block mt-4 text-sm font-medium text-brand-600 hover:text-brand-800 transition-colors"
    >
      Read more →
    </a>
  </div>
</article>
