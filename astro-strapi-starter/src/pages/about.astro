---
import Base from '../layouts/Base.astro';
---

<Base title="About | MySite" description="Learn more about us">

  <section class="max-w-3xl mx-auto px-6 py-20">
    <p class="text-brand-500 text-sm font-medium uppercase tracking-widest mb-2">About us</p>
    <h1 class="font-display text-4xl font-bold text-slate-900 mb-6">Hello, we're MySite</h1>
    <p class="text-slate-500 text-lg leading-relaxed mb-6">
      This is a starter site built with <strong class="text-slate-700">Astro</strong>, <strong class="text-slate-700">Tailwind CSS</strong>, and <strong class="text-slate-700">Strapi</strong> as the headless CMS backend.
    </p>
    <p class="text-slate-500 text-lg leading-relaxed">
      Edit this page in <code class="bg-slate-100 text-brand-700 px-1 py-0.5 rounded text-sm">src/pages/about.astro</code>, and manage your content from the Strapi admin panel.
    </p>
  </section>

</Base>
